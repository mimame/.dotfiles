{
  // opencode.jsonc: Configuration for the OpenCode AI agent.
  // This file defines where opencode sends inference requests.
  "$schema": "https://opencode.ai/config.json",
  // Default model. Override at runtime with -m or OPENCODE_MODEL.
  // GLM-5.2 via OpenCode Go ($10/mo): 880 req/5hr, $1.40/$4.40/$0.26 per 1M in/out/cached.
  // For long sessions switch to DeepSeek V4 Pro: `opencode -m opencode-go/deepseek-v4-pro`
  // (3450 req/5hr, 4x more quota) when you don't need GLM's extra intelligence.
  // No context limit override: OpenCode Go plans bill per request, not per token,
  // so the larger native context (128k+) maximizes prefix-cache hit rate across
  // long sessions. Compaction fires rarely, which is the goal — each compaction
  // invalidates the cached prefix and costs an extra request for the summary.
  "model": "opencode-go/glm-5.2",
  "provider": {
    // Custom provider for the local llama-swap proxy.
    // This allows opencode to use any model loaded by llama-server (llama.cpp).
    "llama-swap": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-swap (local)",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      },
      "models": {
        // Model IDs here must match the keys in services.llama-swap.settings.models
        // defined in your NixOS configuration (nixos/hosts/narnia/programs/ai.nix).
        "qwen-coder-3b": {
          "name": "Qwen 2.5 Coder 3B (local - Hyper-Fast)",
          "limit": {
            "context": 16384,
            "output": 4096
          }
        },
        "llama-3b": {
          "name": "Llama 3.2 3B (local - Fast)",
          "limit": {
            "context": 8192,
            "output": 4096
          }
        },
        "gemma-9b": {
          "name": "Gemma 2 9B (local)",
          "limit": {
            "context": 8192,
            "output": 4096
          }
        },
        "mistral-24b": {
          "name": "Mistral Small 24B (local)",
          "limit": {
            "context": 8192,
            "output": 4096
          }
        }
      }
    }
  },
  // MCP servers for tool-augmented workflows.
  "mcp": {
    // macOS-only: brew(1) provides its own MCP server since Homebrew 4.x.
    // Fails gracefully on Linux (brew not installed).
    "brew": {
      "type": "local",
      "command": ["brew", "mcp-server"],
      "enabled": true,
      "timeout": 30000
    },
    // NixOS-only: requires the nix binary. Shows as disconnected on macOS,
    // which is harmless — no functional impact.
    "nixos": {
      "type": "local",
      "command": ["nix", "run", "github:utensils/mcp-nixos", "--"],
      "enabled": true,
      // nix run needs extra time for flake evaluation and Python startup.
      "timeout": 30000
    }
  },
  // Compaction controls how opencode frees context window when it fills up.
  // Tuned for GLM-5.2 / DeepSeek V4 Pro via OpenCode Go (subscription billed
  // per request, not per token). The strategy is to keep the prefix stable for
  // as long as possible: every compaction invalidates the cached prefix and
  // costs an extra request for the summary pass, so firing compaction rarely
  // is more quota-efficient than firing it often, even though each individual
  // request carries more input tokens. The native 128k+ context limit makes
  // this the feasible regime — compaction only fires during genuinely long
  // sessions.
  "compaction": {
    // auto: automatically compact when the context window approaches full.
    // Always enabled — even big contexts eventually fill during long sessions.
    "auto": true,
    // tail_turns: number of recent user+assistant exchanges kept verbatim
    // during compaction. Default is 2, which is very aggressive and drops
    // most of the conversation. With GLM-5.2's large native context we keep
    // 15 turns, giving the model much more working memory after compaction.
    "tail_turns": 15,
    // reserved: token headroom reserved during compaction to prevent
    // overflow while the compaction pass itself runs. 2048 tokens is a safe
    // pad for any model size; too low risks a failed compaction cycle.
    "reserved": 2048,
    // preserve_recent_tokens: Token-bounded cap on verbatim recent turns
    // during compaction. tail_turns alone keeps N exchanges regardless of
    // their size — if one turn contains a massive tool output it can consume
    // the whole compaction budget. preserve_recent_tokens adds a token-space
    // safety floor alongside it. Whichever limit is hit first applies.
    // 48000 ≈ matches 15 turns at average output size.
    "preserve_recent_tokens": 48000
    // prune is not set (defaults to false). Pruning discards old tool
    // outputs. Big context means those outputs remain useful reference;
    // no need to throw them away. Keeping them also preserves cache hits
    // within a compaction window — pruning could invalidate the prefix too.
  }
}
